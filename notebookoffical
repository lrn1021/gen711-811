# The script loops over all R1 files and finds the matching R2
for fq in data/fastqs/*R1_001.fastq.gz ; do
    f=$(basename $fq)               # strips the directory path
    r=$(echo $f | sed 's/_R1_/_R2_/g')  # swaps R1 → R2 to get the paired file

    fastp \
  --in1 data/fastqs/$f \
  --in2 data/fastqs/$r \
  --cut_tail \                    # trim from 3' end
  --poly_g_min_len 4 \            # flag polyG runs ≥ 4 bases
  --cut_tail_mean_quality 25 \    # trim if mean quality drops below Q25
  --cut_tail_window_size 2 \      # sliding window size for quality check
  --disable_adapter_trimming \    # skip adapter trimming (done later by cutadapt)
  -l ${1} \                       # min read length after trimming (200bp here)
  -g \                            # enable polyG trimming
  -Q                              # disable quality filtering (only length filter)

  find data/poly-G-trimmed/ -size 0 -print -delete

  qiime tools import \
  --type "SampleData[PairedEndSequencesWithQuality]" \
  --input-format CasavaOneEightSingleLanePerSampleDirFmt \  # standard Illumina naming format
  --input-path data/poly-G-trimmed \
  --output-path data/results/${projname}_demux
